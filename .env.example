# dock — environment
#
# NEXT_PUBLIC_* vars are inlined at build time by Next.js — restart `next dev`
# AND hard-reload the browser tab after changing them.

# OIDC issuer. The shared Mind CSS (`docker compose up` at the workspace root;
# see ../SOLID-SERVER.md) so a single WebID flows across all sibling prototypes
# (SSO) and the WebID + account live on the same instance. Point at
# https://pods.mindpods.org/ for the live profile.
NEXT_PUBLIC_SOLID_ISSUER=http://localhost:3011/

# The pod base the signed-in WebID lives under (the shared Mind CSS).
NEXT_PUBLIC_POD_BASE_URL=http://localhost:3011/

# Server-only: sqlite store for held CSS account sessions (gitignored).
DOCK_DATA_DIR=./.dock-data

# Server-only: 32-byte key encrypting the held CSS account cookie at rest.
# Auto-falls back to a dev key if unset — set a real one for anything shared.
# DOCK_ACCOUNT_ENC_KEY=change-me-to-a-32-byte-random-string
