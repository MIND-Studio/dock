# mind-home-v0 — environment
#
# NEXT_PUBLIC_* vars are inlined at build time by Next.js — restart `next dev`
# AND hard-reload the browser tab after changing them.

# OIDC issuer. Defaults to the shared production pod so a single WebID flows
# across all sibling prototypes (SSO). For local dev point this at mind-home's
# own CSS so the WebID + account live on the same instance.
NEXT_PUBLIC_SOLID_ISSUER=http://localhost:3082/

# The pod base the signed-in WebID lives under (mind-home's CSS in dev).
NEXT_PUBLIC_POD_BASE_URL=http://localhost:3082/

# Server-only: sqlite store for held CSS account sessions (gitignored).
HOME_DATA_DIR=./.home-data

# Server-only: 32-byte key encrypting the held CSS account cookie at rest.
# Auto-falls back to a dev key if unset — set a real one for anything shared.
# HOME_ACCOUNT_ENC_KEY=change-me-to-a-32-byte-random-string
