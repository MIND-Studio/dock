{
  "name": "dock",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3080",
    "build": "next build",
    "start": "next start --port 3080",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run --passWithNoTests",
    "prepare": "husky",
    "seed:demo": "tsx scripts/seed-demo.ts"
  },
  "dependencies": {
    "@inrupt/solid-client": "^3.0.0",
    "@inrupt/solid-client-authn-browser": "^4.0.0",
    "@inrupt/solid-client-authn-node": "^3.1.1",
    "@mind-studio/core": "^0.7.0",
    "@mind-studio/ui": "^0.7.0",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^17.4.2",
    "next": "16.2.6",
    "next-themes": "^0.4.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "vitest": "^4.1.9",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  }
}
